#!/usr/bin/env bash
# =============================================================================
# RustPolyBot deploy-multi.sh TEMPLATE
# Deploys 3 independent containers: BTC, ETH, SOL
# Features: Market validator integration, Arbitrage/Momentum strategies
#
# SETUP:
# 1. Copy this file and customize the HOST, USER, and KEY variables
# 2. Make sure you have SSH access to your remote server
# 3. Ensure Docker is installed on the remote server
# 4. Run: chmod +x deploy-multi.sh.example && ./deploy-multi.sh.example
# =============================================================================

set -euo pipefail

# ⚙️  CUSTOMIZE THESE VALUES FOR YOUR SERVER
HOST="<YOUR_SERVER_IP>"              # e.g., "192.168.1.100" or "example.com"
USER="<YOUR_USERNAME>"               # e.g., "ubuntu", "root", "ec2-user"
KEY="<PATH_TO_SSH_KEY>"              # e.g., "~/.ssh/id_rsa" or "~/.ssh/server_key.pem"
REMOTE_DIR="~/rustpolybot"           # Remote directory where code will be deployed

# Optional: SSH port (usually 22, customize if non-standard)
SSH_PORT="22"

echo "🚀 Deploying 3 independent RustPolyBot containers to $HOST..."

# 1. Create remote directory structure (including strategies/ and helpers/)
echo "📁 Creating remote directory structure..."
ssh -i "$KEY" "$USER@$HOST" "mkdir -p $REMOTE_DIR/src/strategies $REMOTE_DIR/src/helpers"

# 2. Copy code once
echo "📤 Copying updated code to remote..."
scp -P "$SSH_PORT" -i "$KEY" src/main.rs "$USER@$HOST:$REMOTE_DIR/src/main.rs"
scp -P "$SSH_PORT" -i "$KEY" src/config.rs "$USER@$HOST:$REMOTE_DIR/src/config.rs"
scp -P "$SSH_PORT" -i "$KEY" src/lib.rs "$USER@$HOST:$REMOTE_DIR/src/lib.rs"
scp -P "$SSH_PORT" -i "$KEY" src/risk.rs "$USER@$HOST:$REMOTE_DIR/src/risk.rs"
scp -P "$SSH_PORT" -i "$KEY" src/notifications.rs "$USER@$HOST:$REMOTE_DIR/src/notifications.rs"
scp -i "$KEY" src/market_validator.rs "$USER@$HOST:$REMOTE_DIR/src/market_validator.rs"
scp -i "$KEY" src/toctou_tests.rs "$USER@$HOST:$REMOTE_DIR/src/toctou_tests.rs"
# Copy strategy modules
scp -P "$SSH_PORT" -i "$KEY" src/strategies/mod.rs "$USER@$HOST:$REMOTE_DIR/src/strategies/mod.rs"
scp -P "$SSH_PORT" -i "$KEY" src/strategies/momentum_impl.rs "$USER@$HOST:$REMOTE_DIR/src/strategies/momentum_impl.rs"
scp -P "$SSH_PORT" -i "$KEY" src/strategies/arbitrage_impl.rs "$USER@$HOST:$REMOTE_DIR/src/strategies/arbitrage_impl.rs"
scp -P "$SSH_PORT" -i "$KEY" src/strategies/time_decay_impl.rs "$USER@$HOST:$REMOTE_DIR/src/strategies/time_decay_impl.rs"
scp -i "$KEY" src/strategies/maker_impl.rs "$USER@$HOST:$REMOTE_DIR/src/strategies/maker_impl.rs"
scp -i "$KEY" src/strategies/basis_impl.rs "$USER@$HOST:$REMOTE_DIR/src/strategies/basis_impl.rs"
# Copy helpers modules
scp -P "$SSH_PORT" -i "$KEY" src/helpers/mod.rs "$USER@$HOST:$REMOTE_DIR/src/helpers/mod.rs"
scp -P "$SSH_PORT" -i "$KEY" src/helpers/price.rs "$USER@$HOST:$REMOTE_DIR/src/helpers/price.rs"
scp -P "$SSH_PORT" -i "$KEY" src/helpers/json.rs "$USER@$HOST:$REMOTE_DIR/src/helpers/json.rs"
scp -P "$SSH_PORT" -i "$KEY" src/helpers/time.rs "$USER@$HOST:$REMOTE_DIR/src/helpers/time.rs"
scp -P "$SSH_PORT" -i "$KEY" src/helpers/balance.rs "$USER@$HOST:$REMOTE_DIR/src/helpers/balance.rs"
scp -P "$SSH_PORT" -i "$KEY" src/helpers/nonce.rs "$USER@$HOST:$REMOTE_DIR/src/helpers/nonce.rs"
scp -P "$SSH_PORT" -i "$KEY" .env "$USER@$HOST:$REMOTE_DIR/.env"
scp -P "$SSH_PORT" -i "$KEY" Cargo.toml "$USER@$HOST:$REMOTE_DIR/Cargo.toml"
scp -P "$SSH_PORT" -i "$KEY" Cargo.lock "$USER@$HOST:$REMOTE_DIR/Cargo.lock"
scp -P "$SSH_PORT" -i "$KEY" Dockerfile "$USER@$HOST:$REMOTE_DIR/Dockerfile"


# 3. Build + deploy all 3 containers in one SSH session
ssh -p "$SSH_PORT" -i "$KEY" "$USER@$HOST" bash -s -- "$REMOTE_DIR" << 'REMOTE'
    set -euo pipefail
    cd "$1"

    echo "🧹 Cleaning up old containers and images..."
    docker stop rustpolybot-btc rustpolybot-eth rustpolybot-sol 2>/dev/null || true
    docker rm rustpolybot-btc rustpolybot-eth rustpolybot-sol 2>/dev/null || true
    docker system prune -af --volumes 2>/dev/null || true

    echo "🔨 Building Docker image once..."
    echo "📊 Note: This build includes the market validator integration"
    echo "   - Professional market filtering (crypto, time window, expiry)"
    echo "   - Robust strike price extraction (4 pattern types)"
    echo "   - Binary market support (no explicit strike needed)"
    docker build -t rustpolybot .

    echo "🚀 Starting BTC rustpolybot..."
    docker run -d \
        --restart unless-stopped \
        --name rustpolybot-btc \
        --env-file .env \
        -e CRYPTO_FILTER=btc \
        rustpolybot

    echo "🚀 Starting ETH rustpolybot..."
    docker run -d \
        --restart unless-stopped \
        --name rustpolybot-eth \
        --env-file .env \
        -e CRYPTO_FILTER=eth \
        rustpolybot

    echo "🚀 Starting SOL rustpolybot..."
    docker run -d \
        --restart unless-stopped \
        --name rustpolybot-sol \
        --env-file .env \
        -e CRYPTO_FILTER=sol \
        rustpolybot

    echo "✅ All 3 containers deployed!"
    echo "📜 Status:"
    docker ps --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}" | grep rustpolybot
REMOTE

echo "✅ Deployment complete on server!"
echo "📡 Tailing combined logs (Ctrl+C to stop):"
ssh -p "$SSH_PORT" -i "$KEY" "$USER@$HOST" "docker logs -f rustpolybot-btc rustpolybot-eth rustpolybot-sol --tail 30"

/// Balanced: 2× threshold (-50/+50) — standard protection.
/// Set to dec!(-9999) / dec!(9999) to disable.
/// 10m drift block as fraction of oracle price.
/// 0.0005 = 0.05% of price. Balanced: at BTC=$100k → $50.
/// Set to dec!(9999) to disable.
pub const MOMENTUM_DRIFT_10M_BLOCK_PCT: Decimal = dec!(0.0005);

/// Maximum combined ask sum (YES_ask + NO_ask) allowed for a Momentum entry.
/// Balanced: 3-cent combined spread cap — allows some widening but blocks clearly broken books.
pub const MOMENTUM_MAX_ENTRY_ASK_SUM: Decimal = dec!(1.030);

/// Maximum age (seconds) of the live orderbook snapshot at Momentum entry.
/// Stale snapshots silently retain last-known OBI/depth values — unreliable veto data.
pub const MOMENTUM_MAX_SNAPSHOT_AGE_SECS: i64 = 15;



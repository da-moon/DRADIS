pub const GBOOST_SIGNAL_EXIT_THRESHOLD: Decimal = dec!(0.40);
pub const GBOOST_MAX_EXPOSURE_USDC: Decimal = dec!(4.0);
pub const GBOOST_MIN_MARKET_AGE_SECS: i64 = 300;
pub const GBOOST_TARGET_PROFIT_PERCENT: Decimal = dec!(0.12);

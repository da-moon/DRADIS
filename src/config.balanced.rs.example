pub const GBOOST_MAX_SNAPSHOT_AGE_SECS: i64 = 10;

/// Minimum hourly YES bid / maximum hourly YES ask allowed at GBoost entry.
/// Guards against entering a daily position when the hourly market is near-resolved.
pub const GBOOST_MIN_HOURLY_YES_BID: Decimal = dec!(0.05);
pub const GBOOST_MAX_HOURLY_YES_ASK: Decimal = dec!(0.95);

/// When trading the DAILY market, block DAILY NO entries if hourly YES bid > threshold
/// (strong hourly uptrend → daily NO falls) and block DAILY YES entries if hourly YES
/// ask < (1 − threshold) (strong hourly downtrend → daily YES falls).
/// 0.65 = balanced: allows entries when hourly is 35–65%, blocks when strongly trending.
/// Evidence: 2026-06-17 T1 hourly YES was 0.69 when GBoost entered DAILY NO → −$0.49 loss.
pub const GBOOST_HOURLY_STRONG_TREND_BLOCK: Decimal = dec!(0.65);

/// Seconds BTC spot must stay below (daily_strike − BASIS_BTC_ORACLE_STRIKE_BUFFER)
/// before GBoost YES entries are suppressed. 3600s = 60 min sustained below-strike.
pub const GBOOST_BELOW_STRIKE_SUPPRESS_SECS: i64 = 3600;

// ── GBoost dynamic position sizing ───────────────────────────────────────────

/// Balanced: same as config.rs default floor.
pub const GBOOST_MIN_EXPOSURE_USDC: Decimal = dec!(1.5);

/// Balanced: standard vol threshold.
pub const GBOOST_HIGH_VOL_REGIME_THRESHOLD: f64 = 0.65;

/// Balanced: 50% size reduction in elevated vol.
pub const GBOOST_HIGH_VOL_SIZE_SCALE: f64 = 0.50;

/// Balanced: 15-minute SL cooldown — longer than aggressive, shorter than conservative.
pub const GBOOST_SL_POST_EXIT_COOLDOWN_SECS: i64 = 900;

/// Minimum expected net profit (USDC) after round-trip fees required to place a GBoost entry.
/// Balanced: $0.15 — standard threshold; filters marginal minimum-size signals near fee break-even.
pub const GBOOST_MIN_NET_PROFIT_USDC: Decimal = dec!(0.15);

/// Market-level entry hold lock (seconds) before GBoost may flip direction on a market.
/// Balanced: 180s — two retrain windows; absorbs first post-entry signal oscillation.
pub const GBOOST_MIN_HOLDING_LOCK_SECS: i64 = 180;

/// When the live data distribution deviates
/// significantly from the training distribution (as measured by perpetual's leaf-node
/// chi-squared statistic), GBoost entries are suppressed until the next retrain.
/// Balanced: 5.0 — chi2(df=1) between p95 (3.84) and p99 (6.63); catches real shifts
/// without over-triggering on normal intra-session variance.
pub const GBOOST_CONCEPT_DRIFT_THRESHOLD: f32 = 5.0;

/// Number of recent history snapshots used for the post-retrain drift check.
/// Balanced: 200 ticks (~3 min at normal cadence).
pub const GBOOST_DRIFT_WINDOW: usize = 200;

/// Number of consecutive retrains above GBOOST_CONCEPT_DRIFT_THRESHOLD required
/// before GBoost entries are suppressed.  A single retrain below the threshold
/// resets the counter and clears suppression.
/// Balanced: 3 — requires three consecutive drift triggers, avoiding false positives
/// from short-lived intra-session variance.
pub const GBOOST_DRIFT_CONSECUTIVE_REQUIRED: usize = 3;

/// Number of consecutive BELOW-threshold retrains to clear drift suppression.
/// Balanced: 3 — matches the standard config; confirms regime stability before re-enabling entries.
pub const GBOOST_DRIFT_STABLE_CLEAR_REQUIRED: usize = 3;


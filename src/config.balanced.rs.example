pub const MOMENTUM_WINDOW_BULLISH_BLOCK: Decimal = dec!(0.70);

/// OBI adverse veto: skip entries when the book is moderately stacked against the trade.
pub const MOMENTUM_OBI_ADVERSE_BLOCK: Decimal = dec!(-0.60);

/// OBI exhaustion veto: block entries when the bid side dominates entirely (all buyers, no sellers).

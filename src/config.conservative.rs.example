pub const MAKER_MAX_BID_IMPROVEMENT: Decimal = dec!(0.02);
pub const MAKER_CROSS_BUFFER: Decimal = dec!(0.02);
pub const CROSSES_BOOK_COOLDOWN_SECS: i64 = 60;

/// Won't post maker orders within 45 minutes of expiry.
pub const MAKER_MIN_SECS_TO_EXPIRY: i64 = 2700;
/// Conservative horizon — only looks at markets closing within 12 hours.
pub const MAKER_MAX_SECS_TO_EXPIRY: i64 = 43200;

/// Lower max entry price — only post bids on genuinely uncertain markets.
pub const MAKER_MAX_ENTRY_PRICE: Decimal = dec!(0.48);
pub const MAKER_MAX_COMPLEMENTARY_PRICE: Decimal = dec!(0.58);
pub const MAKER_MIN_ENTRY_PRICE: Decimal = dec!(0.10);

pub const MAKER_TARGET_PROFIT_PERCENT: Decimal = dec!(0.10);
pub const MAKER_STOP_LOSS_PERCENT: Decimal = dec!(0.05);
pub const MAKER_LATE_MARKET_STOP_TIGHTEN_SECS: i64 = 3600;
pub const MAKER_LATE_MARKET_STOP_LOSS_PERCENT: Decimal = dec!(0.04);

/// Longer hold before stop-loss can fire — avoids cutting on noise.
pub const MAKER_MIN_HOLD_SECS_BEFORE_STOP: i64 = 900;
pub const MIN_HOLD_SECS_BEFORE_STOP_LOSS: i64 = MAKER_MIN_HOLD_SECS_BEFORE_STOP;
pub const MAKER_STOP_LOSS_COOLDOWN_SECS: i64 = 900;
pub const MAKER_MAX_COMBINED_BID: Decimal = dec!(0.88);
pub const MAKER_MAX_BOOK_IMBALANCE_RATIO: Decimal = dec!(2.5);

/// Taker-flow / bid-depth drain gate.
/// Conservative: trigger suppression at just 30% bid-depth drain — exits early and
/// blocks aggressively to minimize adverse fills on thin illiquid books.
pub const MAKER_TAKER_FLOW_WINDOW_MS: u64 = 1500;
pub const MAKER_TAKER_FLOW_DRAIN_THRESHOLD: Decimal = dec!(0.30);
/// Conservative: force-exit open positions at OBI < -0.35 — cuts losses before
/// the book has fully turned, accepting a smaller realized loss over a larger one.
pub const MAKER_TOXIC_FLOW_EXIT_OBI: Decimal = dec!(-0.35);

pub const MAKER_SLOW_TREND_THRESHOLD_BTC: Decimal = dec!(400.0);
pub const MAKER_INVENTORY_SKEW_MAX: Decimal = dec!(0.02);

/// Waits 10 minutes after market open before posting any maker orders.
pub const MAKER_MIN_MARKET_AGE_SECS: i64 = 600;
pub const MOMENTUM_MIN_MARKET_AGE_SECS: i64 = 600;
/// Must be strictly > MOMENTUM_EXPIRY_EXIT_SECS (1200s); 5 min breathing room.
pub const MOMENTUM_MIN_SECS_TO_EXPIRY_FOR_ENTRY: i64 = 1500;



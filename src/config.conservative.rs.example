// ============================================================================
// CONSERVATIVE CONFIG EXAMPLE
// ============================================================================
//
// Designed for users who want to minimize risk and drawdown while learning
// the bot's behavior. Lower position sizes, tighter filters, fewer strategies.
//
// Good for: first-time users, small wallets (<$100), high-volatility markets.
//
// To use: copy this file to src/config.rs, then `cargo build --release`.
// ============================================================================

use rust_decimal::Decimal;
use rust_decimal_macros::dec;
use std::time::Duration as StdDuration;

// ============================================================================
// NOTIFICATION SETTINGS (Telegram)
// ============================================================================

pub const ENABLE_TELEGRAM: bool = false;
pub const ENABLE_X: bool = false;


// ============================================================================
// ARBITRAGE STRATEGY PARAMETERS
// ============================================================================

/// Dry-run mode — logs trades without executing them on-chain.
/// ⚠️ Set to `false` only after validating signals in ghost mode for 30+ minutes.
pub const GHOST_MODE: bool = false;
pub const ENABLE_ARBITRAGE_TRADING: bool = true;

/// Requires a wider margin before entering arbitrage — fewer trades, higher quality.
pub const ARBITRAGE_PROFIT_THRESHOLD: Decimal = dec!(0.07);
pub const ARBITRAGE_MAX_TAKER_FEE_BPS: u32 = 1500; // Updated from 100

/// Maximum allowable gap between our safe bid and the current ask on each arb leg.
/// Conservative profile: 3 ticks — only enter when the book is tight on both legs.
pub const ARBITRAGE_MAX_FILL_GAP: Decimal = dec!(0.03);

/// Maximum price allowed for either arb leg (YES bid OR NO bid).
/// Conservative: 0.55 — tighter band than balanced; requires near-symmetric books.
/// Root cause of the 2026-05-19 "10 YES / 40 NO" imbalance (YES=72¢, NO=27¢).
pub const ARBITRAGE_MAX_LEG_PRICE: Decimal = dec!(0.55);
pub const ARBITRAGE_MAX_LEG_OBI: Decimal = dec!(0.50);
pub const ARB_FAK_REHEDGE_BUFFER: Decimal = dec!(0.02);

pub const MAX_SUM_PRICE_FOR_ENTRY: Decimal = dec!(0.96);

/// Minimum shares and order size (exchange minimums — do not lower).
pub const MIN_ORDER_SHARES: Decimal = dec!(1.0);
pub const MIN_ORDER_USDC: Decimal = dec!(1.05);

/// Discount applied to current bid when setting avg_entry for a reconciled orphaned position.
/// Discount applied to current bid when setting avg_entry for a reconciled orphaned position.
/// Guarantees profit_margin ≈ 33% on first tick → immediate TakeProfit exit at current market price.
/// All profiles use the same value — reconciled positions should always exit promptly regardless of style.
pub const RECONCILE_ADOPTED_ENTRY_DISCOUNT: Decimal = dec!(0.25);

/// Requires 90% book depth before firing — very conservative on thin markets.
pub const MIN_LIQUIDITY_FILL_RATIO: Decimal = dec!(0.90);

pub const BUY_PRICE_OFFSET: Decimal = dec!(0.01);
pub const MOMENTUM_BUY_PRICE_OFFSET: Decimal = dec!(0.02);
pub const MOMENTUM_ENTRY_FAK_RETRIES: u32 = 1;
pub const MAX_BUY_LIMIT_PRICE: Decimal = dec!(0.95);
pub const SELL_PRICE_OFFSET: Decimal = dec!(0.01);
pub const MIN_SELL_LIMIT_PRICE: Decimal = dec!(0.01);
pub const EARLY_EXIT_COMBINED_BID_THRESHOLD: Decimal = dec!(0.995);


// ============================================================================
// MOMENTUM & ORACLE SETTINGS (Predictive Arbitrage)
// ============================================================================

/// Momentum is disabled in conservative mode — it's the riskiest strategy.
pub const ENABLE_MOMENTUM_TRADING: bool = false;

pub const MOMENTUM_KELLY_MAX_MULTIPLIER: Decimal = dec!(2.0);
pub const MOMENTUM_MIN_TRADE_SIZE_USDC: Decimal = dec!(3.0);
pub const MOMENTUM_MAX_TRADE_SIZE_USDC: Decimal = dec!(10.0);

/// Requires 3 consecutive confirming ticks to filter fakeouts aggressively.
pub const MOMENTUM_CONFIRMATION_TICKS: u32 = 3;

pub const MOMENTUM_TARGET_PROFIT_PERCENT: Decimal = dec!(0.06);
pub const MOMENTUM_STOP_LOSS_PERCENT: Decimal = dec!(0.10);

/// Requires a very strong reversal before exiting — avoids shaking out on noise.
pub const MOMENTUM_REVERSAL_RATIO: Decimal = dec!(1.00);
pub const MOMENTUM_MIN_HOLD_SECS_BEFORE_REVERSAL: i64 = 60;
pub const MOMENTUM_FILL_CONFIRM_MIN_HOLD_SECS: i64 = 45;
pub const LATE_MARKET_SIZE_THRESHOLD_SECS: i64 = 2400;
pub const MOMENTUM_EXPIRY_EXIT_SECS: i64 = 1200;
pub const MOMENTUM_EXPIRY_MIN_PROFIT_TO_HOLD: Decimal = dec!(0.03);
pub const MOMENTUM_TAKE_PROFIT_CEILING: Decimal = dec!(0.90);

/// Tighter strike buffers — only trade when well away from the strike.
pub const BTC_STRIKE_BUFFER: Decimal = dec!(100.0);
pub const ETH_STRIKE_BUFFER: Decimal = dec!(8.0);
pub const SOL_STRIKE_BUFFER: Decimal = dec!(0.5);

/// Lower max entry price — better risk/reward at conservative prices.
pub const MAX_MOMENTUM_ENTRY_PRICE: Decimal = dec!(0.80);
pub const MAX_MOMENTUM_CROSSING_ENTRY_PRICE: Decimal = dec!(0.65);
pub const MOMENTUM_MIN_ENTRY_PRICE: Decimal = dec!(0.20); // Conservative: 20-80% probability range only
pub const MOMENTUM_CATASTROPHIC_SL_PCT: Decimal = dec!(0.06); // Conservative: tight 6% catastrophic SL

pub const MOMENTUM_WINDOW_SECS: u64 = 5;
pub const MOMENTUM_SHORT_WINDOW_SECS: u64 = 1;
pub const MOMENTUM_SHORT_WINDOW_FRACTION: Decimal = dec!(0.50);
pub const MOMENTUM_ACCELERATION_BYPASS_MULTIPLIER: Decimal = dec!(3.5);
pub const MOMENTUM_DECAY_EXIT_FRACTION: Decimal = dec!(0.30);

/// Higher threshold — only the strongest BTC moves trigger entry.
pub const BTC_MOMENTUM_THRESHOLD: Decimal = dec!(100.0);
pub const ETH_MOMENTUM_THRESHOLD: Decimal = dec!(5.0);
pub const SOL_MOMENTUM_THRESHOLD: Decimal = dec!(0.5);

/// Narrow window consensus filter — blocks entries unless longer-horizon market is near 50/50.
pub const MOMENTUM_WINDOW_BEARISH_BLOCK: Decimal = dec!(0.35);
pub const MOMENTUM_WINDOW_BULLISH_BLOCK: Decimal = dec!(0.65);

/// OBI adverse veto: block on even moderately adverse books — conservative style prioritizes
/// book quality over fill rate.
pub const MOMENTUM_OBI_ADVERSE_BLOCK: Decimal = dec!(-0.50);

/// Maximum combined ask sum (YES_ask + NO_ask) allowed for a Momentum entry.
/// Conservative: tight 2-cent spread cap — only enter on near-perfect books.
pub const MOMENTUM_MAX_ENTRY_ASK_SUM: Decimal = dec!(1.020);

/// Maximum age (seconds) of the live orderbook snapshot at Momentum entry.
/// Stale snapshots silently retain last-known OBI/depth values — unreliable veto data.
pub const MOMENTUM_MAX_SNAPSHOT_AGE_SECS: i64 = 15;


// ============================================================================
// MAKER (PASSIVE LIMIT ORDER) STRATEGY PARAMETERS
// ============================================================================

pub const ENABLE_MAKER_TRADING: bool = true;

pub const MAKER_VELOCITY_BIAS_THRESHOLD: Decimal = dec!(25.0);
pub const MAKER_BID_BUFFER: Decimal = dec!(0.04);

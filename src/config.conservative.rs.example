/// daily follows, making the opposite-side daily entry systematically unprofitable.
pub const GBOOST_HOURLY_STRONG_TREND_BLOCK: Decimal = dec!(0.65);

/// Seconds BTC spot must stay below (daily_strike − BASIS_BTC_ORACLE_STRIKE_BUFFER)

pub const MAKER_ORACLE_DRIFT_PULL_FRAC: Decimal = dec!(0.0003);
pub const MAKER_BID_BUFFER: Decimal = dec!(0.04);
/// Requires a wider spread before posting — more edge per fill.
pub const MAKER_MIN_SPREAD: Decimal = dec!(0.05);
pub const MAKER_BID_IMPROVEMENT: Decimal = dec!(0.01);
pub const MAKER_BID_IMPROVEMENT_RATIO: Decimal = dec!(0.25);
pub const MAKER_MIN_BID_IMPROVEMENT: Decimal = dec!(0.01);
pub const MAKER_MAX_BID_IMPROVEMENT: Decimal = dec!(0.02);
pub const MAKER_CROSS_BUFFER: Decimal = dec!(0.02);
pub const CROSSES_BOOK_COOLDOWN_SECS: i64 = 60;
/// Conservative: longer pause before retrying a rejected entry — lets the book

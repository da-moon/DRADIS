/// Conservative: strict 1.03 — only enter the daily book when it is very tight.
pub const GBOOST_MAX_TARGET_ASK_SUM: Decimal = dec!(1.03);
/// Hourly OBI adverse block for daily entries — conservative blocks even mild adverse hourly OBI.
pub const GBOOST_HOURLY_OBI_ADVERSE_BLOCK: Decimal = dec!(-0.55);
/// OBI momentum-exhaustion gate: block entries when |obi| exceeds threshold.
/// Conservative: 0.70 — tighter than balanced; blocks ≥70% depth imbalance.
pub const GBOOST_OBI_EXHAUSTION_BLOCK: Decimal = dec!(0.70);
pub const GBOOST_SIGNAL_EXIT_THRESHOLD: Decimal = dec!(0.40);
pub const GBOOST_MAX_EXPOSURE_USDC: Decimal = dec!(4.0);
pub const GBOOST_MIN_MARKET_AGE_SECS: i64 = 300;
pub const GBOOST_TARGET_PROFIT_PERCENT: Decimal = dec!(0.12);
pub const GBOOST_STOP_LOSS_PERCENT: Decimal = dec!(0.070); // conservative: 7.0% — raised from 0.055; tighter than balanced
pub const GBOOST_MIN_HOLD_SECS: i64 = 180;
pub const GBOOST_SL_MIN_HOLD_SECS: i64 = 10;
pub const GBOOST_MIN_USABLE_TREES: usize = 30;
pub const GBOOST_MODEL_PATH : &str = "logs/gboost_model_v22f.json";
/// Max fraction of identical labels before skipping a retrain cycle (avoids degenerate storms).
/// Conservative: same threshold — label imbalance is a data quality issue, not a risk preference.
pub const GBOOST_LOOKAHEAD_LABEL_BALANCE_MAX: f64 = 0.80;
/// 60m oracle drift threshold (USD) for the trend-alignment entry gate.
/// Conservative: $150 — tighter than balanced; blocks even moderate counter-trend entries.
pub const GBOOST_TREND_DRIFT_BLOCK_USD: Decimal = dec!(150.0);
pub const GBOOST_MAX_HOURLY_ASK_SUM: Decimal = dec!(1.20);
pub const GBOOST_MIN_HOURLY_BID_SUM: Decimal = dec!(0.70);
pub const GBOOST_MIN_SECS_TO_EXPIRY: i64 = 900;
pub const GBOOST_MAX_SNAPSHOT_AGE_SECS: i64 = 10;

/// Minimum hourly YES bid / maximum hourly YES ask allowed at GBoost entry.
/// Guards against entering a daily position when the hourly market is near-resolved.
pub const GBOOST_MIN_HOURLY_YES_BID: Decimal = dec!(0.05);
pub const GBOOST_MAX_HOURLY_YES_ASK: Decimal = dec!(0.95);

/// Seconds BTC spot must stay below (daily_strike − BASIS_BTC_ORACLE_STRIKE_BUFFER)
/// before GBoost YES entries are suppressed. 3600s = 60 min sustained below-strike.
pub const GBOOST_BELOW_STRIKE_SUPPRESS_SECS: i64 = 3600;

// ── GBoost dynamic position sizing ───────────────────────────────────────────

/// Conservative: very small floor — minimal capital on borderline signals.
pub const GBOOST_MIN_EXPOSURE_USDC: Decimal = dec!(1.0);

/// Conservative: lower vol threshold — reduce size earlier as oracle gets noisy.
pub const GBOOST_HIGH_VOL_REGIME_THRESHOLD: f64 = 0.55;

/// Conservative: more aggressive size reduction in elevated vol (40% of base).
pub const GBOOST_HIGH_VOL_SIZE_SCALE: f64 = 0.40;

/// Conservative: 30-minute SL cooldown — longest wait after an adverse stop.
pub const GBOOST_SL_POST_EXIT_COOLDOWN_SECS: i64 = 1800;

///  When the live data distribution deviates
/// significantly from the training distribution (as measured by perpetual's leaf-node
/// chi-squared statistic), GBoost entries are suppressed until the next retrain.
/// Conservative: 4.0 — slightly below p95 chi2(df=1)=3.84; blocks on moderate
/// distributional shift to protect capital.
pub const GBOOST_CONCEPT_DRIFT_THRESHOLD: f32 = 4.0;

/// Number of recent history snapshots used for the post-retrain drift check.
/// Conservative: 300 ticks (~5 min) — larger window for a more stable chi-squared estimate.
pub const GBOOST_DRIFT_WINDOW: usize = 300;

/// Number of consecutive retrains above GBOOST_CONCEPT_DRIFT_THRESHOLD required
/// before GBoost entries are suppressed.  A single retrain below the threshold
/// resets the counter and clears suppression.
/// Conservative: 4 — very patient; suppresses only on sustained regime shifts to
/// avoid locking out GBoost during brief liquidity events.
pub const GBOOST_DRIFT_CONSECUTIVE_REQUIRED: usize = 4;


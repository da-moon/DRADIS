/// Velocity threshold: 0.001 = 0.10% of oracle price/5s. Aggressive: at BTC=$100k → $100/5s.
pub const MOMENTUM_THRESHOLD_PCT: Decimal = dec!(0.001);

/// Legacy alias kept for LLM advisor prompt references.
pub const BTC_MOMENTUM_THRESHOLD: Decimal = dec!(100.0);

/// Wider window market consensus filter — allows entries even when longer-horizon
/// market is modestly directional.  Set tighter in balanced/conservative profiles.
pub const MOMENTUM_WINDOW_BEARISH_BLOCK: Decimal = dec!(0.22);
pub const MOMENTUM_WINDOW_BULLISH_BLOCK: Decimal = dec!(0.78);

/// OBI adverse veto: only veto on a very strongly adverse book — aggressive style
/// accepts more adverse-selection risk in exchange for higher fill rates.
pub const MOMENTUM_OBI_ADVERSE_BLOCK: Decimal = dec!(-0.75);

/// OBI exhaustion veto: block entries when the bid side dominates entirely (all buyers, no sellers).
/// Aggressive: 0.70 — tightened from 0.80 to avoid buying exhausted rallies.
pub const MOMENTUM_OBI_EXHAUSTION_BLOCK: Decimal = dec!(0.70);

pub const MOMENTUM_OBI_EXHAUST_MAX_ADVERSE_PCT: Decimal = dec!(-0.08);

/// Maximum OBI swing allowed at Momentum entry.
/// Aggressive: 0.95 — only blocks near-total book flips; allows higher-volatility entries.
pub const MOMENTUM_OBI_SWING_BLOCK: Decimal = dec!(0.95);

/// 10-minute oracle drift alignment gate — blocks momentum entries that contradict the
/// medium-term BTC trend (dead-cat bounce / relief-rally filter).
/// Aggressive: 3× threshold (-75/+75) — only vetoes extreme contra-trend moves.
/// Set to dec!(-9999) / dec!(9999) to disable.
/// 10m drift block: 0.00075 = 0.075% of price. Aggressive: at BTC=$100k → $75. Set to dec!(9999) to disable.
pub const MOMENTUM_DRIFT_10M_BLOCK_PCT: Decimal = dec!(0.00075);

/// Maximum combined ask sum (YES_ask + NO_ask) allowed for a Momentum entry.
/// Aggressive: tolerates a wider spread (4-cent combined cap) to maximize fill opportunities.
pub const MOMENTUM_MAX_ENTRY_ASK_SUM: Decimal = dec!(1.040);

/// Maximum age (seconds) of the live orderbook snapshot at Momentum entry.
/// Stale snapshots silently retain last-known OBI/depth values — unreliable veto data.
pub const MOMENTUM_MAX_SNAPSHOT_AGE_SECS: i64 = 15;



/// Session drawdown limit: 6% of collateral with $15 minimum.
/// Higher than balanced/conservative — allows more recovery room before lockout.
pub fn max_session_drawdown(collateral: Decimal) -> Decimal {
    (collateral * dec!(0.06)).max(dec!(15.00))
}



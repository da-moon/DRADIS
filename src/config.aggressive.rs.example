/// When trading the DAILY market, block DAILY NO entries if hourly YES bid > threshold
/// (strong hourly uptrend → daily NO falls) and block DAILY YES entries if hourly YES
/// ask < (1 − threshold) (strong hourly downtrend → daily YES falls).
/// 0.72 = aggressive: only blocks near-resolution extremes, accepts more trend risk.
/// Evidence: 2026-06-17 T1 hourly YES was 0.69 when GBoost entered DAILY NO → −$0.49 loss.
pub const GBOOST_HOURLY_STRONG_TREND_BLOCK: Decimal = dec!(0.72);

/// Seconds BTC spot must stay below (daily_strike − BASIS_BTC_ORACLE_STRIKE_BUFFER)
/// before GBoost YES entries are suppressed. 3600s = 60 min sustained below-strike.
pub const GBOOST_BELOW_STRIKE_SUPPRESS_SECS: i64 = 3600;


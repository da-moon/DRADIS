/// Aggressive: $0.10 — lower bar to allow more entries; higher trade frequency.
pub const GBOOST_MIN_NET_PROFIT_USDC: Decimal = dec!(0.10);

/// Market-level entry hold lock (seconds) before GBoost may flip direction on a market.
/// Aggressive: 120s — shorter lock allows faster direction changes on strong signals.
pub const GBOOST_MIN_HOLDING_LOCK_SECS: i64 = 120;

///  When the live data distribution deviates
/// significantly from the training distribution (as measured by perpetual's leaf-node
/// chi-squared statistic), GBoost entries are suppressed until the next retrain.
/// Aggressive: 7.0 — only blocks on very strong regime shifts (~p99 chi2 level).
pub const GBOOST_CONCEPT_DRIFT_THRESHOLD: f32 = 7.0;

/// Number of recent history snapshots used for the post-retrain drift check.
/// Aggressive: 200 ticks (~3 min at normal cadence) — same as default.
pub const GBOOST_DRIFT_WINDOW: usize = 200;

/// Number of consecutive retrains above GBOOST_CONCEPT_DRIFT_THRESHOLD required
/// before GBoost entries are suppressed.  A single retrain below the threshold
/// resets the counter and clears suppression.
/// Aggressive: 2 — allows one transient spike before suppressing.
pub const GBOOST_DRIFT_CONSECUTIVE_REQUIRED: usize = 2;

/// Number of consecutive BELOW-threshold retrains to clear drift suppression.
/// Aggressive: 2 — clear suppression faster to allow more entries after brief regime shifts.
pub const GBOOST_DRIFT_STABLE_CLEAR_REQUIRED: usize = 2;


#!/usr/bin/env bash
# =============================================================================
# logs-all.sh TEMPLATE
# Streams live logs from the DRADIS container with optional per-asset filtering.
#
# Phase 3f-6: all assets run concurrently inside ONE container.
# There are no separate dradis-btc / dradis-eth / dradis-sol containers.
#
# SETUP:
# 1. Copy this file: cp logs-all.sh.example logs-all.sh
# 2. Fill in HOST, USER, KEY below
# 3. chmod +x logs-all.sh && ./logs-all.sh
#
# USAGE:
#   ./logs-all.sh              # all output from the container
#   ./logs-all.sh btc          # BTC-only lines
#   ./logs-all.sh eth          # ETH-only lines
#   ./logs-all.sh sol          # SOL-only lines
# =============================================================================

# ⚙️  CUSTOMIZE THESE VALUES FOR YOUR SERVER
HOST="<YOUR_SERVER_IP>"              # e.g. "192.168.1.100"
USER="<YOUR_USERNAME>"               # e.g. "ubuntu"
KEY="<PATH_TO_SSH_KEY>"              # e.g. "~/.ssh/id_rsa"
CONTAINER="dradis-live"              # container name on the target server
SSH_PORT="22"

FILTER="${1:-}"

echo "📡 Live logs from ${CONTAINER} (Ctrl+C to stop)"
if [ -n "$FILTER" ]; then
    echo "   🔍 Filtering for: ${FILTER^^}"
fi
echo "───────────────────────────────────────────────────────────────"

if [ -n "$FILTER" ]; then
    ssh -p "$SSH_PORT" -i "$KEY" "$USER@$HOST" \
        "docker logs -f ${CONTAINER} 2>&1 | grep -i --line-buffered '${FILTER}'"
else
    ssh -p "$SSH_PORT" -i "$KEY" "$USER@$HOST" \
        "docker logs -f ${CONTAINER} 2>&1"
fi

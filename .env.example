# ============================================================================
# DRADIS Environment Configuration
# Copy this file to .env and fill in your own values.
#
# DRADIS builds as ONE venue at a time. Fill in only the section for the
# venue you are building:
#
#   • International CLOB  (default build)            → SECTION 1 + SECTION 3
#       cargo build / cargo run
#
#   • US Retail (CFTC-regulated Polymarket US)       → SECTION 2 + SECTION 3
#       cargo run --no-default-features --features us_retail
#
# SECTION 3 (shared) applies to both. The settings for the venue you are NOT
# building are simply ignored — but keeping them out of your .env avoids
# confusion.
# ============================================================================


# ============================================================================
# SECTION 1 — INTERNATIONAL CLOB BUILD  (default)
# ----------------------------------------------------------------------------
# Required for the default build. IGNORED by the us_retail build.
# Authenticates with an on-chain wallet private key (EIP-712 signing).
# ============================================================================

# Your Polymarket trading account private key (REQUIRED for the default build)
# Get this from your Polymarket wallet setup.
# KEEP THIS SECRET - Never commit the actual .env file to git!
POLYMARKET_PRIVATE_KEY=your_private_key_here

# ── POLYGON RPC ENDPOINT (REQUIRED for auto-settlement) ──────────────────────────
# The auto-settlement feature requires a reliable, paid Polygon (EVM) RPC provider.
# Free public RPC endpoints (polygon-rpc.com, Ankr, PublicNode) are unreliable
# and will cause settlement failures with "API key disabled" or nonce gas errors.
#
# ⚠️  Helius is a Solana-only RPC — do NOT use it here. It will return
#     "Method not found" errors because it doesn't support Polygon/EVM methods.
#
# Recommended providers (all have free tiers, all support Polygon):
#  - Alchemy:   https://www.alchemy.com/           (recommended — easy setup)
#  - QuickNode: https://www.quicknode.com/
#  - Infura:    https://infura.io/
#
# Examples:
#   Alchemy:   POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_API_KEY
#   QuickNode: POLYGON_RPC_URL=https://polygon-mainnet.quiknode.pro/YOUR_KEY/
#   Infura:    POLYGON_RPC_URL=https://polygon-mainnet.infura.io/v3/YOUR_API_KEY
#
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Initial trade size in USDC for each position
# Recommended: Start with 1-5 USDC for testing
TRADE_SIZE_USDC=3

# Optional: Filter by crypto type when using multiple containers
# This is set automatically by deploy-multi.sh for each container (btc, eth, sol)
# Only set this if running a single container
# CRYPTO_FILTER=btc


# ============================================================================
# SECTION 2 — US RETAIL BUILD  (--no-default-features --features us_retail)
# ----------------------------------------------------------------------------
# Required ONLY for the CFTC-regulated Polymarket US exchange. IGNORED by the
# default (international CLOB) build.
#
# The US venue does NOT use a wallet private key. Instead, create an API key on
# the Polymarket US developer portal — it issues a Key ID and a Secret Key
# (shown only once). Every request is signed locally with Ed25519; there is no
# JWT/login step.
# ============================================================================

# Developer-portal Key ID (UUID) — sent as the X-PM-Access-Key header. (REQUIRED)
POLYMARKET_US_KEY_ID=00000000-0000-0000-0000-000000000000

# Developer-portal Secret Key — Base64 of the Ed25519 keypair, shown ONCE at
# creation. KEEP THIS SECRET; it is the full signing key. (REQUIRED)
POLYMARKET_US_SECRET_KEY=your_base64_secret_key_here

# ── Optional US tuning ───────────────────────────────────────────────────────
# Override the gateway base URL (defaults to the production endpoint below).
# POLYMARKET_US_BASE_URL=https://api.prod.polymarketexchange.com
# Contracts per arbitrage leg (default 10).
# POLYMARKET_US_TRADE_SIZE=10
# Minimum risk-free edge per YES+NO pair, in dollars (default 0.02).
# POLYMARKET_US_ARB_EDGE=0.02
# Pick one market by slug/question substring (optional).
# POLYMARKET_US_MARKET_FILTER=chiefs
# Keep the dashboard pool tidy — US data lives in logs/us-dradis.db.
# ASSETS=us


# ============================================================================
# SECTION 3 — SHARED  (applies to BOTH builds)
# ============================================================================

# Rust logging level (affects log verbosity)
# Options: trace, debug, info, warn, error
# Recommended: info or debug for monitoring
RUST_LOG=info,dradis=info

# ── Control Tower UI Auth (RECOMMENDED for production) ───────────────────────
# If set, the Control Tower dashboard requires HTTP Basic Auth.
# Leave unset for local development (no login prompt).
# CT_USERNAME=admin
# CT_PASSWORD=change-me-before-deploying

# ── API Key Auth for External Access (optional) ──────────────────────────────
# When set, the DRADIS REST API (:9000) requires X-API-Key: <value> on every
# request. The Control Tower proxy forwards this automatically — no UI changes
# needed. Leave unset for local development (open access on localhost).
# Required if you expose port 9000 externally (e.g. via Cloudflare Tunnel for
# OpenClaw or other third-party integrations).
# DRADIS_API_KEY=replace-with-a-strong-random-secret

# ── Read-Only Demo Mode (optional) ───────────────────────────────────────────
# When set to true, the engine rejects EVERY mutating API request (any method
# other than GET/HEAD) with 403 — config patches, viper toggles, position exits,
# chain sync. The live raptor telemetry and all read endpoints keep streaming.
# This is the server-side half of the public demo at dradis.live; pair it with
# NEXT_PUBLIC_DEMO_MODE=true in the Control Tower so the UI shows the demo banner
# and disables controls. Strongly recommended to also force GHOST_MODE on.
# DRADIS_READ_ONLY=true

# ── Optional: Telegram Notifications
# To get these:
# 1. Create a bot using @BotFather to get your token
# 2. Get your chat ID (using a bot like @userinfobot)
# 3. Set pub const ENABLE_TELEGRAM: bool = true; in src/config.rs
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Optional: Alpaca real-time IEX feed for the Tide Raptor ───────────────────
# Powers the "Institutional Pulse" Tide Raptor's equity leg — the real-time
# IBIT/FBTC/ARKB last-trade prints it compares against the live synthetic iNAV.
# Use Alpaca's FREE tier (real-time, IEX-sourced, single-venue — NOT delayed).
# Leave unset to run the Tide Raptor in observe-only mode (synthetic iNAV +
# US-session gating only; pulse held at 0, "Tide Raptor" pill shows offline).
# ALPACA_API_KEY_ID=your_alpaca_key_id_here
# ALPACA_API_SECRET_KEY=your_alpaca_secret_key_here

# ── Optional: The Odds API key for the Sports Raptor ─────────────────────────
# Powers the venue-neutral Sports Raptor's line-movement feed — cross-book h2h
# odds it reduces to a vig-free consensus probability, line drift, and book
# dispersion. Free tier at https://the-odds-api.com (hard ~500 req/mo; the raptor
# polls every 2h ≈ 360 req/mo and logs remaining budget each poll). Leave unset to
# run the Sports Raptor idle/observe-only (neutral snapshot, "Sports Raptor" pill shows offline).
# ODDS_API_KEY=your_the_odds_api_key_here

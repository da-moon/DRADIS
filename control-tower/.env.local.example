# Points to the Rust DRADIS API binary.
# In production, replace with the server's IP/hostname.
NEXT_PUBLIC_API_URL=http://localhost:9000

# API key for DRADIS engine auth (must match DRADIS_API_KEY in root .env).
# Server-side only — never sent to the browser bundle.
DRADIS_API_KEY=CHANGEME


# ── Read-Only Demo Mode (optional) ───────────────────────────────────────────
# Set to true for the public demo at dradis.live. Renders a persistent bottom
# banner ("live, read-only demo → deploy your own") and disables all mutating
# controls (viper toggles, config edits, GHOST/LIVE switch, RTB). Pair with
# DRADIS_READ_ONLY=true on the engine, which enforces read-only server-side.
# Inlined into the browser bundle at build time (NEXT_PUBLIC_*).
# NEXT_PUBLIC_DEMO_MODE=true
